generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- CORE MODELS ---

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  password        String
  role            String    // 'admin' | 'guest' (Evolution du système de rôles)
  job             String?
  title           String?
  avatar          String?
  allowedEntities String?   // ex: "ARCHI,ATELIER" (Legacy/Simple Auth)
  
  organizationId  String?   // Lien direct vers l'organisation principale
  organization    Company?  @relation("UserOrganization", fields: [organizationId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  projects        Project[] // Chef de projet ou assigné
  tasks           Task[]
  timeLogs        TimeLog[]
  files           File[]    @relation("FileOwner")
  inventory       InventoryItem[]
}

// Correspond à la table "organizations" demandée
model Company {
  id          String   @id @default(cuid())
  name        String   // ex: "Micro Gambi"
  code        String   @unique // ex: "ARCHI"
  logo        String?
  
  // Gestion Financière (Architect's Touch)
  balance     Float    @default(0)
  isCollective Boolean @default(false) // True pour "Collectif Cobalt"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations Multi-tenant
  primaryUsers User[]   @relation("UserOrganization")
  projects    Project[]
  files       File[]
  invoices    Invoice[]
  clients     Client[]
  
  // Transactions (Versements au collectif, etc.)
  txFrom      Transaction[] @relation("TxFrom")
  txTo        Transaction[] @relation("TxTo")
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  description String
  date        DateTime @default(now())
  
  fromId      String?
  from        Company? @relation("TxFrom", fields: [fromId], references: [id])
  
  toId        String?
  to          Company? @relation("TxTo", fields: [toId], references: [id])
  
  type        String   // 'CONTRIBUTION', 'PAYMENT', 'TRANSFER'
  status      String   // 'PENDING', 'COMPLETED'
}

// --- MODULES ---

model Project {
  id          String   @id @default(cuid())
  title       String
