generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 1. UTILISATEURS (L'équipe)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   // admin, media, archi
  password  String   // On ajoutera le hash plus tard
}

// 2. CLIENTS (CRM)
model Client {
  id        String    @id @default(cuid())
  name      String
  type      String    // Grand Compte, PME, Asso...
  email     String?
  phone     String?
  address   String?
  projects  Project[]
  invoices  Invoice[]
}

// 3. PROJETS & TÂCHES
model Project {
  id          String   @id @default(cuid())
  title       String
  type        String   // media, archi
  status      String   @default("TODO") // TODO, IN_PROGRESS, DONE
  value       Float    @default(0)
  description String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  tasks       Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  done        Boolean  @default(false)
  timeSpent   Int      @default(0) // En minutes
  timerActive Boolean  @default(false)
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// 4. FINANCE (Factures & Catalogue)
model Invoice {
  id        String   @id @default(cuid())
  number    String   @unique // ex: FAC-2024-001
  status    String   @default("DRAFT") // DRAFT, SENT, PAID
  date      DateTime @default(now())
  totalHT   Float    @default(0)
  
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  items     InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Float
  unitPrice   Float
  
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Service {
  id          String @id @default(cuid())
  name        String
  price       Float
  unit        String // Jour, Forfait...
  category    String // Archi, Media...
  description String?
}

// 5. MATÉRIEL (Inventaire)
model InventoryItem {
  id          String  @id @default(cuid())
  name        String
  category    String
  status      String  @default("AVAILABLE") // AVAILABLE, BORROWED
  borrower    String? // Qui l'a pris ?
  returnDate  DateTime?
}