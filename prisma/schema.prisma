generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 1. UTILISATEURS (L'équipe)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   // admin, media, archi
  password  String   
}

// 2. CLIENTS (CRM)
model Client {
  id        String    @id @default(cuid())
  name      String
  type      String    
  email     String?
  phone     String?
  address   String?
  projects  Project[]
  invoices  Invoice[]
}

// 3. PROJETS & TÂCHES (Version Cockpit Deep Dive)
model Project {
  id           String    @id @default(cuid())
  title        String
  type         String    
  status       String    @default("TODO") 
  priority     String    @default("MEDIUM")
  
  // Personnalisation V2
  value        Float     @default(0)
  budget       Float     @default(0)
  description  String?   
  notes        String?   
  driveLink    String?   
  
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  // Correction pour la migration : valeur par défaut ajoutée
  updatedAt    DateTime  @default(now()) @updatedAt 
  
  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  tasks        Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  done        Boolean  @default(false)
  timeSpent   Int      @default(0) 
  timerActive Boolean  @default(false)
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// 4. FINANCE (Factures & Catalogue)
model Invoice {
  id        String   @id @default(cuid())
  number    String   @unique 
  status    String   @default("DRAFT") 
  date      DateTime @default(now())
  dueDate   DateTime 
  totalHT   Float    @default(0)
  
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items     InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Float
  unitPrice   Float
  
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Service {
  id          String @id @default(cuid())
  name        String
  price       Float
  unit        String 
  category    String 
  description String?
}

// 5. MATÉRIEL (Inventaire)
model InventoryItem {
  id          String    @id @default(cuid())
  name        String
  category    String
  status      String    @default("AVAILABLE") 
  borrower    String?   
  returnDate  DateTime?
}