// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE : Avec SQLite, on ne peut pas utiliser "enum".
// On utilise String et on gère la logique dans le code.

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  password        String
  
  role            String   @default("SALARIE") // HIÉRARCHIE : PRESIDENT, DG, ASSOCIE, SALARIE...
  job             String   @default("Membre")  // MÉTIER : Architecte, Menuisier...
  title           String?                      // TITRE : Fondateur, Associé... <--- AJOUT ICI
  
  avatar          String?
  // Stocké comme texte "ARCHI,ATELIER"
  allowedEntities String 
  
  assignedTasks   Task[]
  borrowedItems   InventoryItem[]
  
  // --- AJOUT CORRECTIF ---
  timeLogs        TimeLog[] // Relation nécessaire pour le Time Tracking
  
  createdAt       DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  title       String
  entity      String   // ARCHI, ATELIER, SCI...
  clientName  String
  status      String   @default("IN_PROGRESS")
  
  phase       String?  // ESQ, APS, APD...
  budget      Float    @default(0)
  
  stockUsed   Boolean  @default(false)

  tasks       Task[]
  wikiPages   WikiPage[]
  invoices    Invoice[]
  
  // --- AJOUT CORRECTIF ---
  timeLogs    TimeLog[] // Relation nécessaire pour le Time Tracking
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WikiPage {
  id        String   @id @default(cuid())
  title     String
  content   String   
  
  // --- AJOUTE LES "?" ICI ---
  projectId String?    // <--- Ajoute le ?
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade) // <--- Ajoute le ?
  
  updatedAt DateTime @updatedAt
}

model Task {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String?
  type      String
  entity    String    // ARCHI, ATELIER...
  invoices  Invoice[]
}

model Invoice {
  id        String   @id @default(cuid())
  number    String   @unique
  totalHT   Float
  status    String   
  dueDate   DateTime
  
  entity    String   // ARCHI, ATELIER...
  
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  
  createdAt DateTime @default(now())
}

model InventoryItem {
  id          String    @id @default(cuid())
  name        String
  category    String
  entity      String    // ARCHI, ATELIER...
  status      String    
  borrowerId  String?
  borrower    User?     @relation(fields: [borrowerId], references: [id])
  returnDate  DateTime?
}

// --- AJOUT POUR LE TIME TRACKING ---

model TimeLog {
  id        String   @id @default(cuid())
  duration  Float    // Durée en heures (ex: 1.5 pour 1h30)
  date      DateTime // Date précise de la saisie
  note      String?  // Commentaire optionnel (ex: "Réunion client")
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}